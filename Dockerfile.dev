FROM php:8.2-fpm-alpine

# Define variáveis de ambiente para desenvolvimento
ENV TZ=America/Sao_Paulo

# Instala dependências do sistema necessárias para compilar pacotes e rodar o Laravel
RUN apk add --no-cache \
    bash \
    curl \
    libpng-dev \
    libxml2-dev \
    zip \
    unzip \
    git \
    oniguruma-dev \
    autoconf \
    g++ \
    make

# Instala o Composer globalmente na imagem de dev
COPY --from=composer:2.6 /usr/bin/composer /usr/bin/composer

# Instala as extensões PHP essenciais
ADD https://github.com/mlocati/docker-php-extension-installer/releases/latest/download/install-php-extensions /usr/local/bin/
RUN chmod +x /usr/local/bin/install-php-extensions && \
    install-php-extensions pdo_mysql mbstring exif pcntl bcmath gd opcache zip

WORKDIR /var/www/html

# Como estamos em ambiente de desenvolvimento local, 
# mantemos permissões flexíveis para o usuário padrão do PHP
RUN chown -R www-data:www-data /var/www/html

EXPOSE 9000

CMD ["php-fpm"]